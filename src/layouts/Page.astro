---
import Skeleton from "./Skeleton.astro";

interface Props {
    title?: string;
}

let { title } = Astro.props;
---

<Skeleton {title} bodyClass="background-carpet">
    <Fragment slot="head"><slot name="head" /></Fragment>

    <slot />
</Skeleton>

<style lang="scss">
    body {
        display: flex;
        flex-direction: column;
    }

    .page-content {
        display: flex;
        flex-direction: column;

        flex-grow: 1;
    }

    .page-navigation {
        display: flex;
        flex-direction: flex;
        justify-content: center;
        align-items: center;
        align-self: center;

        padding: 2rem;
        gap: 1rem;
    }

    .page-footer {
        margin-top: 8rem;
    }
</style>
