---
import StickyNote from "$components/containers/StickyNote.astro";
import NavBlock from "$components/navigation/NavBlock.astro";
import Skeleton from "./Skeleton.astro";

interface Props {
    title: string;
}

let { title } = Astro.props;
---

<Skeleton {title} bodyClass="background-carpet">
    <div class="page-container">
        <a href="#main" class="skip-to-main">
            <StickyNote>Skip to main content</StickyNote>
        </a>
        <slot name="header" />
        <div class="page-layout">
            <div class="navigation">
                <NavBlock>
                    <slot name="navigation" />
                </NavBlock>
                <NavBlock>
                    <slot name="contents" />
                </NavBlock>
            </div>
            <main class="main" id="main" tabindex="-1">
                <slot name="main" />
            </main>
        </div>
    </div>
</Skeleton>

<style lang="scss" is:global>
    .page-container {
        display: flex;
        flex-direction: column;

        align-items: center;
    }

    .page-layout {
        width: 100%;
        max-width: 55rem;

        display: grid;
        grid-template-columns: 12rem 3fr;
        align-items: start;

        padding: 0.5rem;
        margin-bottom: 5rem;
        gap: 1rem;

        &:first-child {
            margin-top: 3rem;
        }
    }

    .navigation {
        display: flex;
        flex-direction: column;

        gap: 1rem;
    }

    .main {
        display: flex;
        flex-direction: column;

        gap: 1.5rem;
    }

    .skip-to-main {
        position: fixed;
        top: 1rem;
        left: 1rem;

        &:not(:focus) {
            transform: translateY(-1000%);
        }
    }

    @media (max-width: 800px) {
        // TODO: Better mobile navigation

        .page-layout {
            display: grid;
            grid-template-columns: 1fr;
        }

        .navigation {
            margin-inline: 1rem;
            margin-bottom: 1rem;

            .nav-block:nth-child(2) {
                display: none;
            }
        }
    }
</style>
