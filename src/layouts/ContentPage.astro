---
import StickyNote from "$components/containers/StickyNote.astro";
import MobileNavigation from "$components/navigation/MobileNavigation.astro";
import NavBlock from "$components/navigation/NavBlock.astro";
import Skeleton from "./Skeleton.astro";

interface Props {
    title: string;
}

let { title } = Astro.props;
---

<Skeleton {title} bodyClass="background-carpet">
    <Fragment slot="head"><slot name="head" /></Fragment>

    <a href="#main" class="skip-to-main">
        <StickyNote>Skip to main content</StickyNote>
    </a>

    <MobileNavigation>
        <NavBlock>
            <slot name="navigation" />
        </NavBlock>
        <NavBlock>
            <slot name="contents" />
        </NavBlock>
    </MobileNavigation>

    <div class="page-container">
        <slot name="header" />
        <div class="page-layout">
            <div class="navigation">
                <NavBlock>
                    <slot name="navigation" />
                </NavBlock>
                <NavBlock>
                    <slot name="contents" />
                </NavBlock>
            </div>
            <main class="main" id="main" tabindex="-1">
                <slot name="main" />
            </main>
        </div>
    </div>
</Skeleton>

<style lang="scss" is:global>
    .page-container {
        display: flex;
        flex-direction: column;

        align-items: center;
    }

    .page-layout {
        width: 100%;
        max-width: 55rem;

        display: grid;
        grid-template-columns: 12rem 3fr;
        align-items: start;

        padding: 0.5rem;
        margin-bottom: 5rem;
        gap: 1rem;

        &:first-child {
            margin-top: 3rem;
        }
    }

    .navigation {
        display: flex;
        flex-direction: column;

        gap: 1rem;
    }

    .main {
        display: flex;
        flex-direction: column;

        gap: 1.5rem;
    }

    .skip-to-main {
        position: fixed;
        top: 1rem;
        left: 1rem;

        z-index: 1000;

        &:not(:focus) {
            transform: translateY(-1000%);
        }
    }

    @media screen and (max-width: 800px) {
        .page-layout {
            display: grid;
            grid-template-columns: 1fr;

            &:first-child {
                margin-top: 4.5rem;
            }
        }

        .navigation {
            display: none;
        }
    }
</style>
