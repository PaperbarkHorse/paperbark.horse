---
import NavBlock from "$components/navigation/NavBlock.astro";
import Skeleton from "./Skeleton.astro";

interface Props {
    title: string;
}

let { title } = Astro.props;
---

<Skeleton {title} bodyClass="background-carpet">
    <div class="page-container">
        <slot name="header" />
        <div class="page-layout">
            <div class="navigation">
                <NavBlock>
                    <slot name="navigation" />
                </NavBlock>
                <NavBlock>
                    <slot name="contents" />
                </NavBlock>
            </div>
            <main class="main">
                <slot name="main" />
            </main>
        </div>
    </div>
</Skeleton>

<style lang="scss">
    .page-container {
        display: flex;
        flex-direction: column;

        align-items: center;
    }

    .page-layout {
        width: 100%;
        max-width: 55rem;

        display: grid;
        grid-template-columns: 12rem 3fr;
        align-items: start;

        padding: 0.5rem;
        margin-bottom: 5rem;
        gap: 1rem;

        &:first-child {
            margin-top: 3rem;
        }
    }

    .navigation {
        display: flex;
        flex-direction: column;

        gap: 1rem;
    }

    .main {
        display: flex;
        flex-direction: column;

        gap: 1.5rem;
    }
</style>
