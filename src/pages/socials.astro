---
import ArrowButton from "$components/elements/buttons/ArrowButton.astro";
import Paper from "$components/containers/Paper.astro";
import PaperTitle from "$components/elements/text/PaperTitle.astro";
import ContentPage from "$layouts/ContentPage.astro";
import NavSection from "$components/navigation/NavSection.astro";
import NavItem from "$components/navigation/NavItem.astro";

import DiscordIcon from "$assets/icons/discord.svg";
import TelegramIcon from "$assets/icons/telegram.svg";
import SteamIcon from "$assets/icons/steam.svg";
import TumblrIcon from "$assets/icons/tumblr.svg";
import LastFmIcon from "$assets/icons/lastfm.svg";
import BlueskyIcon from "$assets/icons/bluesky.svg";
import GitHubIcon from "$assets/icons/github.svg";
---

<ContentPage title="Social Links">
    <Fragment slot="navigation">
        <NavSection name="Navigation">
            <NavItem name="Home" href="/" />
        </NavSection>
    </Fragment>

    <Fragment slot="contents">
        <NavSection name="On This Page">
            <NavItem name="Social Links" href="#social-links" />
        </NavSection>
    </Fragment>

    <Fragment slot="main">
        <Paper>
            <PaperTitle el="h1" title="Social Links" />
            <div class="link-group">
                <a class="link" href="/discord" style="--bg: #5865f2; --fg: #ffffff;">
                    <div class="icon">
                        <DiscordIcon class="icon-image" style="transform: scale(1.1);" />
                    </div>
                    <div class="details">
                        <span class="service">Discord</span>
                        <span class="name">PaperbarkHorse</span>
                    </div>
                </a>
                <a
                    class="link"
                    href="https://t.me/PaperbarkHorse"
                    target="_blank"
                    rel="noreferrer"
                    style="--bg: #0088cc; --fg: #ffffff;"
                >
                    <div class="icon">
                        <TelegramIcon class="icon-image" />
                    </div>
                    <div class="details">
                        <span class="service">Telegram</span>
                        <span class="name">@PaperbarkHorse</span>
                    </div>
                </a>
                <a
                    class="link"
                    href="https://steamcommunity.com/id/paperbark/"
                    target="_blank"
                    rel="noreferrer"
                    style="--bg: #171D25; --fg: #ffffff;"
                >
                    <div class="icon">
                        <SteamIcon class="icon-image" />
                    </div>
                    <div class="details">
                        <span class="service">Steam</span>
                        <span class="name">Paperbark</span>
                    </div>
                </a>
                <a
                    class="link"
                    href="https://www.last.fm/user/PaperbarkHorse"
                    target="_blank"
                    rel="noreferrer"
                    style="--bg: #d51007; --fg: #ffffff;"
                >
                    <div class="icon">
                        <LastFmIcon class="icon-image" />
                    </div>
                    <div class="details">
                        <span class="service">Last.fm</span>
                        <span class="name">PaperbarkHorse</span>
                    </div>
                </a>
                <a
                    class="link"
                    href="https://www.tumblr.com/paperbarkhorse"
                    target="_blank"
                    rel="noreferrer"
                    style="--bg: #35465c; --fg: #ffffff;"
                >
                    <div class="icon">
                        <TumblrIcon class="icon-image" style="transform: scale(1.1);" />
                    </div>
                    <div class="details">
                        <span class="service">Tumblr</span>
                        <span class="name">paperbarkhorse</span>
                    </div>
                </a>
                <a
                    class="link"
                    href="https://bsky.app/profile/paperbark.horse"
                    target="_blank"
                    rel="noreferrer"
                    style="--bg: #1185FE; --fg: #ffffff;"
                >
                    <div class="icon">
                        <BlueskyIcon class="icon-image" style="transform: scale(0.95) translateY(2%);" />
                    </div>
                    <div class="details">
                        <span class="service">Bluesky</span>
                        <span class="name">@paperbark.horse</span>
                    </div>
                </a>
                <a
                    class="link"
                    href="https://github.com/PaperbarkHorse"
                    target="_blank"
                    rel="noreferrer"
                    style="--bg: #232925; --fg: #ffffff;"
                >
                    <div class="icon">
                        <GitHubIcon class="icon-image" style="transform: scale(1.2);" />
                    </div>
                    <div class="details">
                        <span class="service">GitHub</span>
                        <span class="name">PaperbarkHorse</span>
                    </div>
                </a>
            </div>
            <div class="button-container">
                <ArrowButton href="https://paperbark.atabook.org/" external={true}>
                    <span style="font-size: 1.1rem; padding: 0.2rem 0.2rem;">Sign my guestbook!</span>
                </ArrowButton>
            </div>
        </Paper>
    </Fragment>
</ContentPage>

<style lang="scss">
    .socials-block {
        display: flex;
        flex-direction: column;

        width: 100%;
        max-width: 30rem;

        align-self: center;

        padding: 0.5rem;

        gap: 2rem;
    }

    .link-group {
        display: flex;
        flex-direction: column;

        gap: 0.5rem;
    }

    .link {
        position: relative;
        display: flex;
        flex-direction: row;
        align-items: center;

        padding: 0.6rem 0.9rem;
        gap: 0.7rem;

        background: var(--bg);
        border-radius: 0.5rem;

        text-decoration: none;
        color: var(--fg);

        > .icon {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        > .icon .icon-image {
            width: 2.2rem;
        }

        > .details {
            display: flex;
            flex-direction: column;
        }

        .service {
            font-size: 1.4rem;
            font-weight: 600;
            line-height: 1;
        }

        .name {
            font-size: 1rem;
            font-weight: 400;
            line-height: 1.4;
        }
    }

    .button-container {
        display: flex;
        flex-direction: column;
        align-items: center;

        margin-top: 1rem;
        gap: 1rem;
    }
</style>
