---
import Page from "$layouts/Page.astro";
import ContentBlock from "$components/blocks/ContentBlock.astro";
import Paper from "$components/containers/Paper.astro";
import Content from "$components/elements/Content.astro";
import PaperTitle from "$components/elements/PaperTitle.astro";
import Polaroid from "$components/elements/Polaroid.astro";
import Link from "$components/elements/Link.astro";
---

<Page title="Paperbark">
    <ContentBlock>
        <Paper>
            <PaperTitle>
                <h1>Paperbark</h1>
            </PaperTitle>
            <Content theme="paper">
                <figure class="float">
                    <Polaroid src="/images/ocs/paperbark/profile.jpg" />
                    <figcaption>
                        Artwork by <Link href="https://beatlinked.carrd.co/">Beatlinked</Link>
                    </figcaption>
                </figure>
                <p>
                    <strong>Paperbark</strong> is my main ponysona! They're a gentle unicorn pony who loves to archive
                    and preserve memories.
                </p>
            </Content>
        </Paper>
    </ContentBlock>
</Page>
