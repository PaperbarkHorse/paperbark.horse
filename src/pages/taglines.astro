---
import ContentPage from "$layouts/ContentPage.astro";
import Paper from "$components/containers/Paper.astro";
import PaperTitle from "$components/elements/text/PaperTitle.astro";
import NavSection from "$components/navigation/NavSection.astro";
import NavItem from "$components/navigation/NavItem.astro";
import StickyNote from "$components/containers/StickyNote.astro";
import Content from "$components/elements/text/Content.astro";
import { getCollection } from "astro:content";

function prettifyQuote(text: string, type: string): string {
    if (type === "song") {
        return `&#9835;&nbsp;${text}&nbsp;&#9835;`;
    } else if (type === "quote") {
        return `&ldquo;${text}&rdquo;`;
    } else {
        return text;
    }
}

const quotes = (await getCollection("tagline"))
    .toSorted((a, b) => a.id.padStart(5, "0").localeCompare(b.id.padStart(5, "0")))
    .map((tagline) => {
        return {
            id: tagline.id,
            type: tagline.data.type,
            text: prettifyQuote(tagline.data.text, tagline.data.type),
            href: tagline.data.href,
        };
    });
---

<ContentPage title="Taglines">
    <Fragment slot="navigation">
        <NavSection name="Navigation">
            <NavItem name="Home" href="/" />
        </NavSection>
    </Fragment>

    <Fragment slot="contents">
        <NavSection name="On This Page">
            <NavItem name="Taglines" href="#taglines" />
        </NavSection>
    </Fragment>

    <Fragment slot="main">
        <Paper>
            <PaperTitle el="h1" title="Taglines" />
            <Content theme="paper">
                <p>
                    Taglines are the small bits of text which appear under my name in a sticky note
                    <a href="/">on the homepage</a>. Head over there and try giving it a refresh if you don't
                    know what I'm talking about. Clicking on some of them even takes you to a relevant
                    video/webpage if you want more context!
                </p>
                <p>
                    Here is the full list of all {quotes.length} taglines that can appear:
                </p>
                <p></p>
            </Content>
        </Paper>
        <div class="tagline-list">
            {
                quotes.map((quote) => (
                    <a href={quote.href} class="tagline" target="_blank" rel="noreferrer noopener">
                        <StickyNote padding={false}>
                            <div class="tagline-inner">
                                <Fragment set:html={quote.text} />
                                <code class="id">{quote.id}</code>
                            </div>
                        </StickyNote>
                    </a>
                ))
            }
        </div>
    </Fragment>
</ContentPage>

<style lang="scss">
    .tagline-list {
        display: grid;
        grid-template-columns: 1fr;
        justify-items: center;
        align-items: center;

        gap: 1em;
    }

    .tagline-inner {
        max-width: 34ch;

        padding: 1.2rem 2.5rem;

        font-weight: var(--font-medium);
        text-align: center;
        text-wrap: balance;
        line-height: 1.25;

        .id {
            position: absolute;
            top: 0.2rem;
            left: 0.25rem;
        }
    }
</style>
