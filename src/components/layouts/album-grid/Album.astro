---
interface Props {
    title?: string;
    artist?: string;
    cover?: string;
    href?: string;
}

let { title, artist, cover, href } = Astro.props;
---

<a class="album" {href}>
    {cover ? <img src={cover} alt="" class="cover" /> : <div class="placeholder-cover">{title}</div>}
    <div class="details">
        {title && <span class="title">{title}</span>}
        {artist && <span class="artist">{artist}</span>}
    </div>
</a>

<style lang="scss">
    .album {
        display: flex;
        flex-direction: column;
        container-type: inline-size;

        gap: 0.8rem;

        .cover,
        .placeholder-cover {
            box-shadow: var(--shadow-medium);
            transform: scale(100%);
            z-index: 0;

            transition-property: box-shadow, transform, z-index;
            transition-duration: 0.15s;
        }

        &:hover,
        &:focus-visible {
            .cover,
            .placeholder-cover {
                box-shadow: var(--shadow-large);
                transform: scale(105%);
                z-index: 50;
            }
        }

        .cover {
            border-radius: 0.25rem;

            aspect-ratio: 1;
            object-fit: cover;
        }

        .placeholder-cover {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;

            padding: 5cqw;

            border: 5cqw solid #ffe300;
            border-radius: 0.25rem;

            background-color: white;

            font-size: 12cqw;
            font-weight: var(--font-medium);
            text-align: center;

            aspect-ratio: 1;
            object-fit: cover;
        }

        .details {
            display: flex;
            flex-direction: column;
            align-items: center;

            gap: 0.4rem;

            text-align: center;
            line-height: 1.1;
        }

        .title {
            font-weight: var(--font-semibold);
        }
    }
</style>
