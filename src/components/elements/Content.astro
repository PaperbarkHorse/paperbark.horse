---
interface Props {
    theme?: "default" | "paper" | "sticky-note";
    style?: string;
}

const { theme = "default", style } = Astro.props;
---

<div class="content" {style} class:list={[`theme-${theme}`]}>
    <slot />
</div>

<style>
    .content {
        --content-gap: 1.25em;

        width: 100%;

        > :not(.float) + * {
            margin-top: var(--content-gap);
        }

        > h1,
        > h2,
        > h3,
        > h4,
        > h5,
        > h6 {
            font-weight: var(--font-semibold);
            line-height: 1.2;
        }

        > h1 {
            font-size: 3rem;
        }

        > h2 {
            font-size: 2rem;
        }

        > h3 {
            font-size: 1.5rem;
        }

        > h4 {
            font-size: 1.25rem;
        }

        > p.subheading {
            --content-gap: 0;
            font-weight: var(--font-medium);

            b,
            strong {
                font-weight: var(--font-bold);
            }
        }

        > p {
            i,
            em {
                font-style: italic;
            }

            b,
            strong {
                font-weight: var(--font-semibold);
            }
        }

        > ul,
        > ol {
            padding-left: 1em;
        }

        > table {
            align-self: flex-start;
            border-collapse: collapse;

            td,
            th {
                padding: 0.1rem 0.3rem;
            }

            th {
                padding-top: 0.2rem;
                border-bottom: 0.15rem solid rgba(0, 0, 0, 0.2);
            }

            th[scope="row"] {
                text-align: right;
                border-bottom: none;
            }
        }

        > figure {
            display: flex;
            flex-direction: column;
            align-items: center;

            gap: 0.5rem;

            figcaption {
                align-self: normal;

                font-style: italic;
                text-align: center;
            }
        }

        > .button-container {
            display: flex;
            flex-direction: row;
            gap: 1rem;
            flex-wrap: wrap;
        }

        > .float {
            margin-bottom: 1rem;
        }
    }

    .content.theme-paper {
        > :is(p, ul, ol, table, figure) a[href] {
            background-color: var(--highlighter-yellow);
            mix-blend-mode: multiply;

            border-top-left-radius: 1.8em 0.6em;
            border-bottom-left-radius: 1em 0.9em;
            border-top-right-radius: 0.9em 1em;
            border-bottom-right-radius: 1.8em 0.6em;
            box-decoration-break: clone;

            padding-inline: 0.2em;
            margin-inline: -0.2em;
            padding-block: 0.05em;
            margin-block: -0.05em;

            &[target="_blank"] {
                background-color: var(--highlighter-green);
            }
        }
    }

    .content.theme-sticky-note {
        --content-gap: 1em;

        > h1,
        > h2,
        > h3,
        > h4,
        > h5,
        > h6 {
            font-weight: var(--font-bold);
            line-height: 1.2;
            font-size: 1.2rem;
        }

        > .button-container {
            justify-content: center;
        }
    }

    @media screen and (min-width: 550px) {
        .content {
            > .float {
                max-width: 20ch;
                float: right;

                margin-left: 0.5rem;
                margin-bottom: 0.5rem;
            }
        }
    }
</style>
