---
interface Props {
    src?: string;
    alt?: string;
    width?: string;
    dynamic?: boolean;
    angle?: string;
}

const { src, alt = "", width, dynamic = false, angle = "0deg" } = Astro.props;
---

<div class:list={["polaroid", { dynamic }]} style={{ "--polaroid-width": width, "--polaroid-angle": angle }}>
    {src ? <img {src} {alt} /> : <slot />}
</div>

<style is:global lang="scss">
    :root {
        --polaroid-width: min(100%, 12.5rem);
        --polaroid-edge: calc(var(--polaroid-width) * 0.05);
        --polaroid-angle: 0deg;
    }
</style>

<style lang="scss">
    .polaroid {
        position: relative;

        display: flex;
        flex-direction: column;

        width: var(--polaroid-width);
        aspect-ratio: 85 / 100;

        padding-top: var(--polaroid-edge);
        padding-left: var(--polaroid-edge);
        padding-right: var(--polaroid-edge);

        background-image: linear-gradient(-45deg, #f3f3f3, #ffffff);

        box-shadow: var(--shadow-medium);
        rotate: var(--polaroid-angle);
        scale: 100%;
        z-index: 0;

        img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
        }
    }
</style>

<style lang="scss" is:global>
    @media screen and not (prefers-reduced-motion: reduce) {
        .polaroid.dynamic {
            transition-property: rotate, scale, box-shadow;
            transition-duration: 0.12s;
            transition-timing-function: ease-out;
        }

        .polaroid.dynamic:hover,
        .group:hover .polaroid.dynamic,
        .group:focus-visible .polaroid.dynamic {
            rotate: 0deg;
            scale: 109%;
            z-index: 10;

            box-shadow: var(--shadow-large);
        }
    }
</style>
