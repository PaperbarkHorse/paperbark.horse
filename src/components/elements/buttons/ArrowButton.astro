---
interface Props {
    href: string;
    direction?: "none" | "backwards" | "forwards";
    color?: "yellow" | "green" | "white" | "blue";
    size?: "normal" | "large";
    external?: boolean;
    download?: string;
    visualCenter?: boolean;
}

let {
    href,
    download,
    external = false,
    direction = "forwards",
    color = "yellow",
    size = "normal",
    visualCenter = false,
} = Astro.props;

if (external === undefined) {
    let url = new URL(href, Astro.site);
    external = url.host !== Astro.site?.host;
}
---

<a
    {href}
    {download}
    class:list={[
        "arrow-button",
        `direction-${direction}`,
        `sticky-note-color-${color}`,
        `sticky-note-size-${size}`,
        { "visual-center": visualCenter },
    ]}
    target={external ? "_blank" : undefined}
    rel={external ? "noreferrer noopener" : undefined}
>
    <div class="arrow-button-inner">
        <slot />
    </div>
</a>

<style lang="scss">
    .arrow-button {
        --arrow-size: 1.4em;

        filter: var(--filter-shadow-medium);

        .arrow-button-inner {
            position: relative;
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: center;

            padding-block: 0.5em;
            padding-inline: 1.25em;

            border-radius: 0.2rem;

            background-image: var(--sticky-note-yellow-gradient);

            font-weight: var(--font-semibold);
            text-align: center;
            color: var(--text-black);
        }

        &.direction-forwards .arrow-button-inner {
            padding-left: 1.25em;
            padding-right: 2.25em;
            clip-path: polygon(
                0 0,
                calc(100% - var(--arrow-size)) 0,
                100% 50%,
                calc(100% - var(--arrow-size)) 100%,
                0 100%
            );
        }

        &.direction-backwards .arrow-button-inner {
            padding-left: 2.25em;
            padding-right: 1.25em;
            clip-path: polygon(0 50%, var(--arrow-size) 0, 100% 0, 100% 100%, var(--arrow-size) 100%);
        }

        &.direction-forwards.visual-center {
            margin-right: calc(var(--arrow-size) * -1);
        }

        &.direction-backwards.visual-center {
            margin-left: calc(var(--arrow-size) * -1);
        }

        &.sticky-note-color-yellow .arrow-button-inner {
            background-image: var(--sticky-note-yellow-gradient);
        }

        &.sticky-note-color-green .arrow-button-inner {
            background-image: var(--sticky-note-green-gradient);
        }

        &.sticky-note-color-white .arrow-button-inner {
            background-image: var(--sticky-note-white-gradient);
        }

        &.sticky-note-color-blue .arrow-button-inner {
            background-image: var(--sticky-note-blue-gradient);
        }

        &.sticky-note-size-large .arrow-button-inner {
            font-size: 1.2rem;
            line-height: 1.75;
        }
    }
</style>
