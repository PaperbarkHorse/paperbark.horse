---
interface Props {
    width?: string;
}

const { width } = Astro.props;
---

<div class="content-block" style={{ "--block-width": width }}>
    <slot />
</div>

<style lang="scss">
    .content-block {
        display: flex;
        flex-direction: column;

        width: 100%;
        max-width: var(--block-width, var(--site-content-width));
        align-self: center;

        padding-inline: var(--site-content-edge);

        &:not(:first-child) {
            margin-top: var(--site-content-spacing);
        }
    }
</style>
