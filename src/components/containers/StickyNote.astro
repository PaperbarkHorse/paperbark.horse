---
interface Props {
    padding?: boolean;
    color?: "yellow" | "green" | "white";
}

const { padding = true, color = "yellow" } = Astro.props;
---

<div class:list={["sticky-note", "theme-sticky-note", `sticky-note-color-${color}`, { padding }]}>
    <div class="sticky-note-inner">
        <slot />
    </div>
</div>

<style lang="scss">
    .sticky-note {
        filter: var(--filter-shadow-medium);

        &.padding .sticky-note-inner {
            padding: 1rem 1.5rem;
        }

        &.sticky-note-color-yellow .sticky-note-inner {
            background-image: var(--sticky-note-yellow-gradient);
        }

        &.sticky-note-color-green .sticky-note-inner {
            background-image: var(--sticky-note-green-gradient);
        }

        &.sticky-note-color-white .sticky-note-inner {
            background-image: var(--sticky-note-white-gradient);
        }
    }

    .sticky-note-inner {
        --sticky-note-fold-size: 1.2rem;
        --sticky-note-corner-radius: 0.2rem;

        position: relative;

        border-radius: var(--sticky-note-corner-radius);

        color: var(--text-black);

        clip-path: polygon(
            0 0,
            100% 0,
            100% calc(100% - var(--sticky-note-fold-size)),
            calc(100% - var(--sticky-note-fold-size)) 100%,
            0 100%
        );

        &::after {
            content: "";
            position: absolute;
            bottom: 0;
            right: 0;
            width: var(--sticky-note-fold-size);
            height: var(--sticky-note-fold-size);

            border-top-left-radius: var(--sticky-note-corner-radius);

            background-color: #00000012;
        }
        &::after {
            content: "";
            position: absolute;
            bottom: 0;
            right: 0;
            width: var(--sticky-note-fold-size);
            height: var(--sticky-note-fold-size);

            border-top-left-radius: var(--sticky-note-corner-radius);

            background-color: rgba(0, 0, 0, 0.08);
        }
    }
</style>

<style lang="scss" is:global>
    .main > .sticky-note {
        margin-inline: 1rem;
    }
</style>